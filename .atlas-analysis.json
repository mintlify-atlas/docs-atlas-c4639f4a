  "keyFeatures": [
    "1,000+ pre-built tool integrations (GitHub, Slack, Gmail, Notion, etc.)",
    "Session-based tool routing with per-user isolation",
    "Built-in OAuth and API key authentication management",
    "Model Context Protocol (MCP) server support",
    "Adapters for 12+ AI frameworks: OpenAI, Anthropic, LangChain, CrewAI, Vercel, Mastra, and more",
    "Real-time triggers via webhooks and polling",
    "Persistent Python sandbox (Workbench) for code execution",
    "Custom tool and toolkit creation",
    "Modifier middleware for schema, input, and output transformation",
    "Proxy execution for direct authenticated HTTP requests",
    "CLI for managing tools, connections, and code generation"
  ],
  "publicApiSurface": [
    "Composio({ apiKey, provider, baseURL, toolkitVersions, ... })",
    "composio.tools.get(userId, { toolkits, tools, search, limit })",
    "composio.tools.execute(slug, arguments, { userId, modifiers })",
    "composio.create(userId, sessionConfig) → ToolRouterSession",
    "composio.use(sessionId) → ToolRouterSession",
    "session.tools(modifiers?) → ProviderToolCollection",
    "session.authorize(toolkit, ...) → ConnectLink",
    "session.mcp.url / session.mcp.headers",
    "composio.triggers.subscribe() → TriggerSubscription",
    "composio.triggers.verify_webhook(id, payload, secret, signature, timestamp)",
    "composio.mcp.create(name, config) → MCPServer",
    "composio.mcp.generate(userId, mcpConfigId) → MCPServerInstance",
    "composio.connectedAccounts.link(userId, authConfigId) → ConnectionRequest",
    "composio.authConfigs.create(toolkit, options)",
    "composio.experimental.tool() decorator",
    "@composio/core: Composio, Tools, MCP, RemoteFile, ToolRouterSession",
    "@composio/openai: OpenAIProvider, OpenAIResponsesProvider",
    "@composio/anthropic: AnthropicProvider",
    "@composio/langchain: LangchainProvider",
    "@composio/vercel: VercelProvider",
    "@composio/google: GoogleProvider",
    "@composio/mastra: MastraProvider",
    "@composio/openai-agents: OpenAIAgentsProvider",
    "@composio/cloudflare: CloudflareProvider",
    "@composio/llamaindex: LlamaindexProvider",
    "composio CLI: login, tools list/search/execute, triggers, connected-accounts, generate ts/py, mcp"
  ]
}
